{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Debugar Vite",
      "url": "http://localhost:5173",
      // ATENÇÃO AQUI: Se o seu .vscode está na pasta raiz do repositório, use a linha abaixo:
      "webRoot": "${workspaceFolder/src}",
      // Se o seu .vscode já está DENTRO da pasta CashRegisterApp, mude a linha acima para: "${workspaceFolder}"
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/src/*",
        "webpack:///src/*": "${webRoot}/src/*",
        "/*": "${webRoot}/*"
      }
    }
  ]
}
